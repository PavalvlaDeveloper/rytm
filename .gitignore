# Composer зависимости (устанавливаются через composer install)
/vendor/
/composer.lock   # если хотите, чтобы composer.lock тоже игнорировался, обычно его коммитят, но для чистоты можно исключить

# Переменные окружения (секреты) – НИКОГДА не коммитить!
.env
.env.local
.env.*.local

# Логи (системные ошибки, отладочная информация)
/logs/
*.log

# Хранилище пользовательских файлов (биты, сниппеты, временные данные)
/storage/beats/
/storage/snippets/
/storage/temp/

# Публичные загрузки (временные файлы и аватарки пользователей – не храним в Git)
/public/uploads/temp/
/public/uploads/avatars/

# Файлы IDE и системные мусорные файлы
.idea/
.vscode/
.DS_Store
Thumbs.db
*.sublime-*
*.swp
*.swo
*~

# Кеши, сборка, временные файлы
*.cache
*.tmp
.phpunit.result.cache
.phpcs-cache

# Конфиги с локальными настройками (если есть)
/local.config.php
/phpunit.xml